# =============================================================================
# Local Development Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# .env.local is in .gitignore and will not be committed
# =============================================================================

# =============================================================================
# Telegram Bot (DEV)
# =============================================================================
# Create a new bot for development:
# 1. Go to @BotFather in Telegram
# 2. Send /newbot
# 3. Follow instructions
# 4. Get your dev bot token
# 5. Paste it here:
DEV_TELEGRAM_BOT_TOKEN=YOUR_DEV_BOT_TOKEN_HERE

# Optional: Allow only your Telegram user ID
# ALLOWED_USER_IDS=123456789

# =============================================================================
# OpenAI
# =============================================================================
# Use the same key as production or create a separate one
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Database (automatically configured via docker-compose.dev.yml)
# =============================================================================
# No need to change these unless you modify docker-compose.dev.yml
# DB_URL=postgresql://dev:dev123@localhost:5433/vacancy_mirror_dev
# DB_PASSWORD=dev123

# =============================================================================
# Google Sheets (optional for dev)
# =============================================================================
# You can use the same sheet as production or create a dev sheet
GOOGLE_SHEETS_ID=YOUR_GOOGLE_SHEETS_ID_HERE
# GOOGLE_SERVICE_ACCOUNT_JSON is mounted via docker-compose volumes

# =============================================================================
# Chatwoot (optional for dev)
# =============================================================================
CHATWOOT_BASE_URL=https://www.app.vacancy-mirror.com/
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=2
CHATWOOT_API_ACCESS_TOKEN=YOUR_CHATWOOT_TOKEN_HERE
CHATWOOT_WEBHOOK_TOKEN=YOUR_WEBHOOK_TOKEN_HERE

# =============================================================================
# Stripe (TEST MODE)
# =============================================================================
# Use test keys for development
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_TEST_WEBHOOK_SECRET_HERE

# =============================================================================
# SMTP (Email sending)
# =============================================================================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=support@vacancy-mirror.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD_HERE
SMTP_TLS=true
SUPPORT_FROM_EMAIL=support@vacancy-mirror.com

# =============================================================================
# Internal API (for scraper communication)
# =============================================================================
SCRAPER_API_KEY=dev-scraper-key-not-needed-locally

# =============================================================================
# Optional: Proxy settings (if testing scraper locally)
# =============================================================================
# PROXY_URL=http://user:pass@proxy:80
# WEBSHARE_API_KEY=your_key

