{
  "id": null,
  "uid": "telegram-support-feedback",
  "title": "Telegram Support Feedback",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Feedback (24h)",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "backend_support_pg"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::bigint AS value FROM support_feedback_events WHERE created_at >= NOW() - INTERVAL '24 hours';"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Telegram Reply Requested (24h)",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "backend_support_pg"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::bigint AS value FROM support_feedback_events WHERE reply_channel = 'telegram' AND created_at >= NOW() - INTERVAL '24 hours';"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Email Reply Requested (24h)",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "backend_support_pg"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::bigint AS value FROM support_feedback_events WHERE reply_channel = 'email' AND created_at >= NOW() - INTERVAL '24 hours';"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Latest Support Feedback",
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 4},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "backend_support_pg"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT created_at, telegram_user_id, telegram_username, telegram_full_name, reply_channel, NULLIF(reply_email, '') AS reply_email, feedback_message FROM support_feedback_events ORDER BY created_at DESC LIMIT 300;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    }
  ]
}

