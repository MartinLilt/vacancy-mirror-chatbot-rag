      "options": {
        "mode": "html",
        "content": "<style>*{box-sizing:border-box}#term{display:flex;flex-direction:column;height:calc(100% - 8px);background:#0d0d0d;border-radius:6px;overflow:hidden;font-family:'Courier New',monospace}#out{flex:1;overflow-y:auto;padding:10px 12px;font-size:12px;line-height:1.55;color:#d4d4d4;min-height:0;white-space:pre-wrap;word-break:break-word}#input-row{display:flex;align-items:center;padding:6px 10px;border-top:1px solid #222;background:#111}#prompt{color:#00e676;margin-right:6px;font-size:12px;white-space:nowrap}#cmd{flex:1;background:transparent;border:none;outline:none;color:#fff;font-family:'Courier New',monospace;font-size:12px;caret-color:#00e676}.g{color:#69f0ae}.r{color:#ef5350}.y{color:#ffa726}.b{color:#42a5f5}.d{color:#888}.w{color:#fff}.m{color:#ce93d8}</style><div id=\"term\"><div id=\"out\"></div><div id=\"input-row\"><span id=\"prompt\">scraper&gt;</span><input id=\"cmd\" autocomplete=\"off\" autocorrect=\"off\" spellcheck=\"false\" placeholder=\"type 'help' and press Enter\"></div></div><script>(function(){const API='http://178.104.110.28:8000';const KEY='vm-scraper-api-key-2026';const CAT_NAMES={'531770282580668418':'Web, Mobile & Software Dev','531770282580668420':'Data Science & Analytics','531770282580668421':'Design & Creative','531770282580668419':'IT & Networking','531770282580668422':'Sales & Marketing','531770282580668416':'Admin Support','531770282580668417':'Customer Service','531770282584862721':'Accounting & Consulting','531770282584862722':'Engineering & Architecture','531770282584862723':'Legal','531770282580668423':'Writing','531770282584862720':'Translation'};let state={step:null,jobsPage:1};let logTimer=null;let statusTimer=null;let prevStatus=null;let lastLogLen=0;const out=document.getElementById('out');const inp=document.getElementById('cmd');function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}function print(html){out.innerHTML+=html+'\\n';out.scrollTop=out.scrollHeight;}function printLine(cls,text){print('<span class=\"'+cls+'\">'+esc(text)+'</span>');}function sep(){print('<span class=\"d\">'+'─'.repeat(60)+'</span>');}function ready(){state={step:null,jobsPage:state.jobsPage||1};document.getElementById('prompt').textContent='scraper> ';}function showHelp(){sep();print('<span class=\"g\">  Chaos Scraper Console — Commands:</span>');print('<span class=\"w\">  status</span>            <span class=\"d\">— scraper API status (running/idle)</span>');print('<span class=\"w\">  chaos</span>             <span class=\"d\">— chaos state: progress per category</span>');print('<span class=\"w\">  stop</span>              <span class=\"d\">— stop running scraper</span>');print('<span class=\"w\">  logs [N]</span>          <span class=\"d\">— show last N log lines (default 80)</span>');print('<span class=\"w\">  jobs [N]</span>          <span class=\"d\">— show last N jobs from DB (default 20)</span>');print('<span class=\"w\">  jobs more</span>         <span class=\"d\">— next page of jobs</span>');print('<span class=\"w\">  clear</span>             <span class=\"d\">— delete all jobs from DB (idle only)</span>');print('<span class=\"w\">  cls</span>               <span class=\"d\">— clear console output</span>');print('<span class=\"w\">  help</span>              <span class=\"d\">— this message</span>');sep();print('<span class=\"d\">  Chaos scraper runs automatically via cron (Mon–Sat 8–22).</span>');print('<span class=\"d\">  State resets every Monday. No manual start needed.</span>');sep();}function apiFetch(path,opts){return fetch(API+path,opts).then(r=>{if(!r.ok)return r.json().then(e=>{throw new Error(e.detail||r.status);});return r.json();});}function startLogPoll(){stopLogPoll();lastLogLen=0;logTimer=setInterval(pollLogs,4000);}function stopLogPoll(){if(logTimer){clearInterval(logTimer);logTimer=null;}}function pollLogs(){apiFetch('/logs?lines=150').then(d=>{const lines=d.lines||[];const atBottom=out.scrollHeight-out.scrollTop-out.clientHeight<80;if(lines.length>lastLogLen){const fresh=lines.slice(lastLogLen);lastLogLen=lines.length;fresh.forEach(l=>{const cls=l.includes('Ban/Cloudflare')||l.includes('ERROR')?'r':l.includes('WARNING')?'y':'g';print('<span class=\"'+cls+'\">'+esc(l)+'</span>');});if(atBottom)out.scrollTop=out.scrollHeight;}}).catch(()=>{});}function startStatusPoll(){if(statusTimer)return;statusTimer=setInterval(()=>{apiFetch('/status').then(d=>{if(prevStatus==='running'&&d.status==='idle'){stopLogPoll();lastLogLen=0;sep();printLine('g','✅ Scraper session finished — status: IDLE');sep();}prevStatus=d.status;}).catch(()=>{});},5000);}function cmdStatus(){apiFetch('/status').then(d=>{sep();const s=d.status;if(s==='running'){print('<span class=\"b\">  🔄 Status  : <span class=\"w\">RUNNING</span></span>');print('<span class=\"d\">  Started  : <span class=\"w\">'+(d.started_at||'—')+'</span></span>');print('<span class=\"d\">  Watching logs automatically...</span>');startLogPoll();}else{print('<span class=\"g\">  ✅ Status  : <span class=\"w\">IDLE</span></span>');}sep();}).catch(e=>printLine('r','Error: '+e.message)).finally(()=>ready());}function cmdChaos(){apiFetch('/chaos-state').then(d=>{sep();print('<span class=\"g\">  Chaos Scraper — Weekly Progress (target: '+d.target_per_cat+' per category)</span>');sep();const cats=d.categories||[];const total=cats.reduce((a,c)=>a+c.collected,0);cats.sort((a,b)=>b.collected-a.collected);cats.forEach(c=>{const pct=Math.min(100,Math.round(c.collected/d.target_per_cat*100));const bar='█'.repeat(Math.round(pct/5))+'░'.repeat(20-Math.round(pct/5));const col=pct>=100?'g':pct>=50?'b':'y';const name=(c.name||c.uid).slice(0,30).padEnd(30);print('  <span class=\"d\">'+esc(name)+'</span> <span class=\"'+col+'\">'+bar+'</span> <span class=\"w\">'+c.collected+'</span><span class=\"d\">/'+d.target_per_cat+' ('+pct+'%)</span>  <span class=\"d\">'+c.visited_pages+' pages visited</span>');});sep();print('<span class=\"d\">  Total in DB: <span class=\"w\">'+total+'</span>  |  State file: <span class=\"w\">'+(d.state_file||'chaos_state.json')+'</span></span>');if(d.reset_day)print('<span class=\"d\">  Resets every: <span class=\"w\">Monday</span></span>');sep();}).catch(e=>{printLine('y','  /chaos-state not available — showing DB count only');apiFetch('/jobs?page=1&page_size=1').then(d=>printLine('d','  Total jobs in DB: '+d.total)).catch(()=>{});}).finally(()=>ready());}function cmdLogs(arg){const n=parseInt(arg)||80;apiFetch('/logs?lines='+n).then(d=>{const lines=d.lines||[];sep();if(!lines.length){printLine('d','  (log buffer is empty)');sep();ready();return;}lines.forEach(l=>{const cls=l.includes('Ban/Cloudflare')||l.includes('ERROR')?'r':l.includes('WARNING')||l.includes('ban')?'y':'g';print('<span class=\"'+cls+'\">'+esc(l)+'</span>');});sep();printLine('d','  '+lines.length+' lines shown.');ready();}).catch(e=>{printLine('r','Error: '+e.message);ready();});}function cmdJobs(arg){const n=(!arg||arg==='more')?20:parseInt(arg)||20;if(arg==='more')state.jobsPage++;else state.jobsPage=1;const offset=(state.jobsPage-1)*n;apiFetch('/jobs?page='+state.jobsPage+'&page_size='+n).then(d=>{sep();print('<span class=\"g\">  Jobs in DB: <span class=\"w\">'+d.total+'</span>  — showing '+(offset+1)+'–'+Math.min(offset+n,d.total)+'  (page '+state.jobsPage+'/'+d.pages+')</span>');print('<span class=\"d\">  #    Title                                    Country      Budget      Date</span>');print('<span class=\"d\">  '+'─'.repeat(78)+'</span>');d.jobs.forEach((j,i)=>{const title=(j.title||'').slice(0,40).padEnd(40);const country=(j.client_country||'—').slice(0,10).padEnd(12);const budget=j.hourly_budget_min?('$'+j.hourly_budget_min+'–$'+(j.hourly_budget_max||'?')+'/h').padEnd(12):(j.weekly_budget?('$'+j.weekly_budget+'/w').padEnd(12):'  —         ');const date=(j.published_at||j.scraped_at||'').slice(0,10);print('<span class=\"d\">  '+(offset+i+1)+'. </span><span class=\"w\">'+esc(title)+'</span><span class=\"d\"> '+esc(country)+esc(budget)+' '+esc(date)+'</span>');});sep();if(state.jobsPage<d.pages)printLine('d','  Type \"jobs more\" for next page.');ready();}).catch(e=>{printLine('r','Error: '+e.message);ready();});}function cmdStop(){apiFetch('/stop',{method:'POST',headers:{'X-API-Key':KEY}}).then(d=>printLine(d.ok?'g':'y',(d.ok?'⏹ ':'⚠ ')+d.message)).catch(e=>printLine('r','Error: '+e.message)).finally(()=>ready());}function cmdClear(){apiFetch('/status').then(d=>{if(d.status==='running'){printLine('r','Cannot clear DB while running. Stop first.');ready();return;}printLine('y','⚠ This will delete ALL jobs from DB. Type YES to confirm:');state.step='clear_confirm';document.getElementById('prompt').textContent='confirm> ';}).catch(e=>{printLine('r','Error: '+e.message);ready();});}function handleStep(val){if(state.step==='clear_confirm'){state.step=null;document.getElementById('prompt').textContent='scraper> ';if(val.trim()==='YES'){apiFetch('/jobs/clear',{method:'POST',headers:{'X-API-Key':KEY}}).then(r=>printLine('g','🗑 Deleted '+r.deleted_rows+' rows.')).catch(e=>printLine('r','Error: '+e.message)).finally(()=>ready());}else{printLine('d','Cancelled.');ready();}return;}}inp.addEventListener('keydown',function(e){if(e.key!=='Enter')return;const raw=inp.value.trim();inp.value='';if(!raw)return;print('<span class=\"m\">'+esc(document.getElementById('prompt').textContent)+'</span><span class=\"w\">'+esc(raw)+'</span>');if(state.step){handleStep(raw);return;}const parts=raw.trim().split(/\\s+/);const cmd=parts[0].toLowerCase();const arg=parts[1]||'';if(cmd==='help'||cmd==='?'){showHelp();}else if(cmd==='status'){cmdStatus();}else if(cmd==='chaos'||cmd==='progress'||cmd==='state'){cmdChaos();}else if(cmd==='stop'){cmdStop();}else if(cmd==='logs'){cmdLogs(arg);}else if(cmd==='jobs'){cmdJobs(arg);}else if(cmd==='clear'){cmdClear();}else if(cmd==='cls'){out.innerHTML='';printLine('d','Console cleared.');}else if(cmd==='start'||cmd==='run'||cmd==='runs'||cmd==='schedule'){printLine('y','ℹ \"'+esc(cmd)+'\" не используется в chaos-режиме.');printLine('d','  Скрапер запускается автоматически через cron (Mon–Sat 8–22).');printLine('d','  Используй: status, chaos, logs, jobs, stop, clear');}else{printLine('r','Unknown: '+esc(raw)+'. Type \"help\".');}});print('<span class=\"g\">  Vacancy Mirror — Chaos Scraper Console</span>');print('<span class=\"d\">  Type <span class=\"w\">help</span> for commands  |  <span class=\"w\">chaos</span> — weekly progress  |  <span class=\"w\">logs</span> — live log</span>');sep();apiFetch('/status').then(d=>{prevStatus=d.status;const s=d.status;const col=s==='running'?'b':'g';print('<span class=\"d\">  API connected. Status: <span class=\"'+col+'\">'+esc(s)+'</span></span>');if(s==='running'){print('<span class=\"d\">  Attaching log stream...</span>');startLogPoll();}startStatusPoll();}).catch(()=>printLine('r','  ⚠ Cannot reach scraper-api at '+API));})();</script>"
