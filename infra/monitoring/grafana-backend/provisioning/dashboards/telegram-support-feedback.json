{
  "id": null,
  "uid": "telegram-support-feedback",
  "title": "Telegram Support Feedback",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-30d",
    "to": "now"
