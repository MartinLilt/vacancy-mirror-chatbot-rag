  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Support Inbox",
      "gridPos": {"h": 18, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "backend_support_pg"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT id, created_at, status, telegram_user_id, telegram_username, telegram_full_name, reply_channel, NULLIF(reply_email, '') AS reply_email, feedback_message, NULLIF(assigned_to, '') AS assigned_to, last_reply_at FROM support_feedback_events ORDER BY created_at DESC LIMIT 500;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    }
  ]
}

